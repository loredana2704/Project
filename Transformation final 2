    df = df.rename(columns={
        "cid": "id",
        "cntry": "country"
    })

    df = df[[
        "id",
        "country"
    ]]

    insert_dataframe("erp_location", df)


def transform_erp_product_category():
    query = f"SELECT * FROM {SOURCE_SCHEMA}.erp_px_cat_g1v2"
    df = load_table(query)

    df = df.dropna(subset=["id"])
    df = df.drop_duplicates(subset=["id"], keep="last").copy()

    df["id"] = df["id"].astype(str).str.strip()
    df["cat"] = df["cat"].astype(str).str.strip().replace("", pd.NA)
    df["subcat"] = df["subcat"].astype(str).str.strip().replace("", pd.NA)
    df["maintenance"] = df["maintenance"].astype(str).str.strip()

    df["maintenance"] = df["maintenance"].str.upper().replace({
        "YES": "1",
        "NO": "0",
        "": pd.NA
    })

    df = df.rename(columns={
        "id": "id",
        "cat": "category",
        "subcat": "subcategory",
        "maintenance": "requires_maintenance"
    })

    df = df[[
        "id",
        "category",
        "subcategory",
        "requires_maintenance"
    ]]

    insert_dataframe("erp_product_category", df)


def main():
    transform_crm_customer()
    transform_crm_product()
    transform_crm_sales()
    transform_erp_customer()
    transform_erp_location()
    transform_erp_product_category()
    print("All transformation tables loaded successfully")


if __name__ == "__main__":
    main()
